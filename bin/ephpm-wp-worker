#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * ephpm-wp-worker — WordPress entrypoint for ePHPm persistent worker mode.
 *
 * ePHPm launches this script for each persistent worker (point
 * `[php] worker_script` at it, or at a copy of it inside your project). It:
 *
 *   1. locates and loads this package's Composer autoloader,
 *   2. locates the WordPress root (EPHPM_WP_PATH env var, or ABSPATH if already
 *      defined, or a walk upward looking for wp-load.php),
 *   3. boots WordPress ONCE and runs the worker loop via Ephpm\WordPress\Worker.
 *
 * Requires `[php] worker_populate_superglobals = true` in ephpm.toml — WordPress
 * assumes real $_SERVER/$_GET/$_COOKIE superglobals. See the package README.
 */

use Ephpm\WordPress\RedirectSignal;
use Ephpm\WordPress\RestServed;
use Ephpm\WordPress\Worker;
use Ephpm\Worker\Runtime;

// --- 1. Locate the Composer autoloader (search upward from CWD & script). -----
$__ephpm_autoload = null;
foreach ([getcwd() ?: __DIR__, __DIR__] as $__seed) {
    $__dir = $__seed;
    while (true) {
        $__cand = $__dir . DIRECTORY_SEPARATOR . 'vendor' . DIRECTORY_SEPARATOR . 'autoload.php';
        if (is_file($__cand)) {
            $__ephpm_autoload = $__cand;
            break 2;
        }
        $__parent = dirname($__dir);
        if ($__parent === $__dir) {
            break;
        }
        $__dir = $__parent;
    }
}

if ($__ephpm_autoload === null) {
    fwrite(STDERR, "ephpm-wp-worker: could not locate vendor/autoload.php (run composer install).\n");
    exit(1);
}

require $__ephpm_autoload;

// --- 2. Fail fast if not under ePHPm worker mode. -----------------------------
Runtime::assertAvailable();

// --- 3. Locate the WordPress root. --------------------------------------------
$__abs = $argv[1] ?? getenv('EPHPM_WP_PATH') ?: null;
if ($__abs === null && defined('ABSPATH')) {
    $__abs = ABSPATH;
}
if ($__abs === null) {
    $__dir = getcwd() ?: __DIR__;
    while (true) {
        if (is_file($__dir . DIRECTORY_SEPARATOR . 'wp-load.php')) {
            $__abs = $__dir;
            break;
        }
        $__parent = dirname($__dir);
        if ($__parent === $__dir) {
            break;
        }
        $__dir = $__parent;
    }
}
if ($__abs === null) {
    fwrite(
        STDERR,
        "ephpm-wp-worker: could not locate WordPress.\n"
        . "Set EPHPM_WP_PATH to the WordPress root, or pass it as the first argument.\n"
    );
    exit(1);
}
$__abs = rtrim($__abs, "/\\") . '/';
if (!is_file($__abs . 'wp-load.php')) {
    fwrite(STDERR, "ephpm-wp-worker: no wp-load.php under {$__abs}\n");
    exit(1);
}

// --- 4. Boot WordPress ONCE at GLOBAL scope. ----------------------------------
// This MUST be a top-level require (not inside a function/method): wp-settings.php
// creates $wpdb/$table_prefix/$wp_the_query/... without `global`, so a function
// -scoped require would trap them in the call frame and destabilise WordPress
// (the worker crashes during template rendering). See the Worker class docblock.
Worker::defineBootConstants($__abs);
require $__abs . 'wp-load.php';

// --- 5. Run the worker loop against the resident WordPress. -------------------
// The loop lives HERE, at global scope, because wp() + the template loader + the
// theme all assume global scope (running them inside a method traps their
// top-level variables and crashes the worker). The Worker object only provides
// the marshaling/reset/response helpers.
// NB: not named $wp — that global is WordPress's own WP router object.
$__ephpmWorker = new Worker($__abs);
$__ephpmWorker->installHooks();

while (($__env = \Ephpm\Worker\take_request()) !== null) {
    ob_start();
    try {
        $__target = $__ephpmWorker->beforeRequest($__env);
        if ($__target !== null) {
            // A concrete entry script (wp-login.php, wp-admin/*, ...). It re-uses
            // the resident WordPress and typically exit()s at the end; this build
            // delivers the captured output on exit.
            require $__target;
        } else {
            // Front controller: routing + main query + template, at global scope.
            wp();
            require ABSPATH . WPINC . '/template-loader.php';
        }
        [$__st, $__hd, $__body] = Worker::finishResponse((string) ob_get_clean());
        \Ephpm\Worker\send_response($__st, $__hd, $__body);
    } catch (RedirectSignal $__r) {
        while (ob_get_level() > 0) {
            ob_end_clean();
        }
        [$__st, $__hd, $__body] = Worker::redirectResponse($__r);
        \Ephpm\Worker\send_response($__st, $__hd, $__body);
    } catch (RestServed $__rs) {
        while (ob_get_level() > 0) {
            ob_end_clean();
        }
        [$__st, $__hd, $__body] = Worker::restResponse($__rs);
        \Ephpm\Worker\send_response($__st, $__hd, $__body);
    } catch (\Throwable $__e) {
        while (ob_get_level() > 0) {
            ob_end_clean();
        }
        [$__st, $__hd, $__body] = Worker::errorResponseTriple($__e);
        \Ephpm\Worker\send_response($__st, $__hd, $__body);
    }
}

exit(0);
